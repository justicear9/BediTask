# Copy to project root as ".env" and edit for each environment:
#   cp env.example .env
#
# CodeIgniter reads this from the directory above app/ (project root).
#
# Production "Whoops / hit a snag" = hidden exception. Fix:
#   1) Set database.* below for your host (defaults in Database.php are local-only).
#   2) chmod -R 775 writable && chown -R www-data:www-data writable (user/group per host).
#   3) Check writable/logs/log-*.php after reproducing the error.
#   4) Temporarily: CI_ENVIRONMENT = development (revert after debugging).

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# development | production | testing
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# URL (recommended in production — trailing slash)
#--------------------------------------------------------------------
# app.baseURL = https://your-domain.com/

#--------------------------------------------------------------------
# DATABASE (required — matches table prefix rise_)
#--------------------------------------------------------------------
database.default.hostname = 127.0.0.1
database.default.username = your_db_user
database.default.password = your_db_password
database.default.database = your_db_name

# Local XAMPP-style (adjust to match your MySQL user/db):
# database.default.username = root
# database.default.password =
# database.default.database = task
database.default.DBDriver = MySQLi
database.default.port = 3306
database.default.DBPrefix = rise_

#--------------------------------------------------------------------
# ENCRYPTION (optional — RISE sets a default in app/Config/App.php)
#--------------------------------------------------------------------
# Override only if you rotate keys. Use the App config key name:
# app.encryption_key = your-long-random-string
# Or from CLI: php spark key:generate  (then copy the suggested line)

#--------------------------------------------------------------------
# RISE LICENSE (default: same as localhost — hostname-based, no FairSketch)
#--------------------------------------------------------------------
# By default the app does not call FairSketch and uses a synthetic key for the browser check.
# For official Envato purchase verification + update API, set:
# RISE_USE_FAIRSKETCH_LICENSE = true
# Then use Settings → Updates with your purchase code.
# Optional override for app_verification_key (usually not needed):
# RISE_APP_VERIFICATION_KEY =
# RISE_FORCE_FAIRSKETCH = false
